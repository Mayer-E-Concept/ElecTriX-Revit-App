<Project Sdk="Microsoft.NET.Sdk">

  <!--
    ME-Tools für Autodesk Revit — Mayer E-Concept SRL
    Debug   → entwickeln + testen (auto-deploy nach Revit 2025)
    Release → für Installer (kein auto-deploy)
  -->

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>METools</AssemblyName>
    <RootNamespace>METools</RootNamespace>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>9</LangVersion>
    <Company>Mayer E-Concept SRL</Company>
    <Product>ME-Tools for Autodesk Revit</Product>
    <Copyright>© 2025 Mayer E-Concept SRL</Copyright>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <!-- Revit 2025 API -->
  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <!-- Project files -->
  <ItemGroup>
    <None Update="METools.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <EmbeddedResource Include="Icons\*.png" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="SymmetricDistributor_Revit2025\**" />
    <EmbeddedResource Remove="SymmetricDistributor_Revit2025\**" />
    <None Remove="SymmetricDistributor_Revit2025\**" />
    <Page Remove="SymmetricDistributor_Revit2025\**" />
    <Compile Remove="KonfigFenster.xaml.cs" />
    <Page Remove="KonfigFenster.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Icons\" />
  </ItemGroup>

  <!-- Post-Build: auto-deploy bei Debug -->
  <Target Name="DeployDebug" AfterTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <PropertyGroup>
      <RevitDir>C:\ProgramData\Autodesk\Revit\Addins\2025</RevitDir>
    </PropertyGroup>
    <MakeDir Directories="$(RevitDir)" Condition="!Exists('$(RevitDir)')" />
    <Copy SourceFiles="$(OutputPath)METools.dll"
          DestinationFolder="$(RevitDir)" SkipUnchangedFiles="false" ContinueOnError="true" />
    <Copy SourceFiles="$(ProjectDir)METools.addin"
          DestinationFolder="$(RevitDir)" SkipUnchangedFiles="false" ContinueOnError="true" />
    <Message Text="✓ ME-Tools deployed to $(RevitDir)" Importance="high" />
  </Target>

</Project>
