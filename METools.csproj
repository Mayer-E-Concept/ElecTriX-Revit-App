<Project Sdk="Microsoft.NET.Sdk">

  <!--
    ME-Tools für Autodesk Revit — Mayer E-Concept SRL
    Supports Revit 2024 (.NET 4.8) and Revit 2025/2026 (.NET 8.0)

    Build configurations:
      Release2024  → net4.8  → deployed to Revit 2024 folder
      Release2025  → net8.0  → deployed to Revit 2025 folder
      Release2026  → net8.0  → deployed to Revit 2026 folder
      Debug        → net8.0  → deployed to Revit 2025 folder (development)
  -->

  <PropertyGroup>
    <!-- Multi-target: net48 for Revit 2024, net8.0-windows for 2025/2026 -->
    <TargetFrameworks>net48;net8.0-windows</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <AssemblyName>METools</AssemblyName>
    <RootNamespace>METools</RootNamespace>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>9</LangVersion>
    <Company>Mayer E-Concept SRL</Company>
    <Product>ME-Tools for Autodesk Revit</Product>
    <Copyright>© 2025 Mayer E-Concept SRL</Copyright>
    <Version>1.0.0</Version>
    <Configurations>Debug;Release2024;Release2025;Release2026</Configurations>
  </PropertyGroup>

  <!-- net4.8 (Revit 2024): needs explicit WPF references -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net48'">
    <DefineConstants>REVIT2024</DefineConstants>
  </PropertyGroup>

  <!-- net8.0-windows (Revit 2025 / 2026) -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <DefineConstants>REVIT2025</DefineConstants>
  </PropertyGroup>

  <!-- Revit 2026: override constant when building Release2026 config -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release2026'">
    <DefineConstants>REVIT2026</DefineConstants>
  </PropertyGroup>

  <!-- ── Revit API References ───────────────────────────────────────────── -->

  <!-- Revit 2024 API (.NET 4.8) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2024\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2024\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- WPF for .NET 4.8 (comes with Windows SDK) -->
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="System.Xaml" />
  </ItemGroup>

  <!-- Revit 2025 API (.NET 8.0) — default for Debug + Release2025 -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' AND '$(Configuration)' != 'Release2026'">
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2025\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <!-- Revit 2026 API (.NET 8.0) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows' AND '$(Configuration)' == 'Release2026'">
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2026\RevitAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2026\RevitAPIUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <!-- ── System.Management for LicenseManager (Hardware ID) ────────────── -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <Reference Include="System.Management" />
  </ItemGroup>

  <!-- ── Project files ─────────────────────────────────────────────────── -->
  <ItemGroup>
    <None Update="METools_2024.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="METools_2025.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="METools_2026.addin">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <EmbeddedResource Include="Icons\*.png" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="SymmetricDistributor_Revit2025\**" />
    <EmbeddedResource Remove="SymmetricDistributor_Revit2025\**" />
    <None Remove="SymmetricDistributor_Revit2025\**" />
    <Page Remove="SymmetricDistributor_Revit2025\**" />
    <Compile Remove="KonfigFenster.xaml.cs" />
    <Page Remove="KonfigFenster.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Icons\" />
  </ItemGroup>

  <!-- ── Post-Build: Auto-deploy to correct Revit version folder ────────── -->

  <!-- Debug → Revit 2025 (development) -->
  <Target Name="DeployDebug" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Debug' AND '$(TargetFramework)' == 'net8.0-windows'">
    <PropertyGroup>
      <RevitDir>C:\ProgramData\Autodesk\Revit\Addins\2025</RevitDir>
    </PropertyGroup>
    <MakeDir Directories="$(RevitDir)" Condition="!Exists('$(RevitDir)')" />
    <Copy SourceFiles="$(OutputPath)METools.dll"    DestinationFolder="$(RevitDir)" ContinueOnError="true" />
    <Copy SourceFiles="$(ProjectDir)METools_2025.addin" DestinationFiles="$(RevitDir)\METools.addin" ContinueOnError="true" />
    <Message Text="✓ ME-Tools deployed to Revit 2025 (Debug)" Importance="high" />
  </Target>

  <!-- Release2024 → Revit 2024 -->
  <Target Name="DeployRelease2024" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release2024' AND '$(TargetFramework)' == 'net48'">
    <PropertyGroup>
      <RevitDir>C:\ProgramData\Autodesk\Revit\Addins\2024</RevitDir>
    </PropertyGroup>
    <MakeDir Directories="$(RevitDir)" Condition="!Exists('$(RevitDir)')" />
    <Copy SourceFiles="$(OutputPath)METools.dll"    DestinationFolder="$(RevitDir)" ContinueOnError="true" />
    <Copy SourceFiles="$(ProjectDir)METools_2024.addin" DestinationFiles="$(RevitDir)\METools.addin" ContinueOnError="true" />
    <Message Text="✓ ME-Tools deployed to Revit 2024" Importance="high" />
  </Target>

  <!-- Release2025 → Revit 2025 -->
  <Target Name="DeployRelease2025" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release2025' AND '$(TargetFramework)' == 'net8.0-windows'">
    <PropertyGroup>
      <RevitDir>C:\ProgramData\Autodesk\Revit\Addins\2025</RevitDir>
    </PropertyGroup>
    <MakeDir Directories="$(RevitDir)" Condition="!Exists('$(RevitDir)')" />
    <Copy SourceFiles="$(OutputPath)METools.dll"    DestinationFolder="$(RevitDir)" ContinueOnError="true" />
    <Copy SourceFiles="$(ProjectDir)METools_2025.addin" DestinationFiles="$(RevitDir)\METools.addin" ContinueOnError="true" />
    <Message Text="✓ ME-Tools deployed to Revit 2025" Importance="high" />
  </Target>

  <!-- Release2026 → Revit 2026 -->
  <Target Name="DeployRelease2026" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release2026' AND '$(TargetFramework)' == 'net8.0-windows'">
    <PropertyGroup>
      <RevitDir>C:\ProgramData\Autodesk\Revit\Addins\2026</RevitDir>
    </PropertyGroup>
    <MakeDir Directories="$(RevitDir)" Condition="!Exists('$(RevitDir)')" />
    <Copy SourceFiles="$(OutputPath)METools.dll"    DestinationFolder="$(RevitDir)" ContinueOnError="true" />
    <Copy SourceFiles="$(ProjectDir)METools_2026.addin" DestinationFiles="$(RevitDir)\METools.addin" ContinueOnError="true" />
    <Message Text="✓ ME-Tools deployed to Revit 2026" Importance="high" />
  </Target>

</Project>
